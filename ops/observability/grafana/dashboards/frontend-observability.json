      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (route, method, status) (rate(woogook_frontend_request_total[5m]))",
          "legendFormat": "{{route}} {{method}} {{status}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Request Rate by Route",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
