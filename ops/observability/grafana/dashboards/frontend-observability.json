      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(woogook_frontend_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{route}}",
          "range": true,
          "refId": "A"
