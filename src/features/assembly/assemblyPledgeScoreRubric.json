{
  "5": {
    "headline": "\u0035\uc810 \u2014 \uc774\ubbf8 \uc644\ub8cc \ub610\ub294 \uc784\uae30 \ub0b4 \uc644\ub8cc \ud655\uc2e4",
    "body": "\uc774\ubbf8 \uc644\ub8cc\ub41c \uc0ac\uc5c5, \uc784\uae30 \ub0b4 \uc644\ub8cc\uac00 \ud655\uc2e4\ud55c \uc0ac\uc5c5, \ub610\ub294 \ud655\ub300\u00b7\uc9c0\uc6d0 \ub4f1\uc5d0\uc11c \uad6c\uccb4\uc801 \ubaa9\ud45c(\uc608: 50% \ud655\ub300)\uac00 \uba85\ud655\ud788 \ub2ec\uc131\ub41c \uacbd\uc6b0 \ub4f1\uc774 \uc5ec\uae30\uc5d0 \ud574\ub2f9\ud569\ub2c8\ub2e4."
  },
  "4.5": {
    "headline": "\u0034\u002e\u0035\uc810 \u2014 \uc644\ub8cc \uc804\uc774\ub098 \uc644\ub8cc \ud655\uc2e4\uc131\uc774 \ub192\uc74c",
    "body": "\uc544\uc9c1 \uc644\ub8cc\ub418\uc9c0\ub294 \uc54a\uc558\uc73c\ub098 \uc784\uae30 \uc9c1\ud6c4(\uc608: 2024\ub144 \uc77c\uc815) \uc644\ub8cc\uac00 \ud655\uc2e4\ud55c \uacbd\uc6b0, \uc804\uc784\uae30\ubd80\ud130 \uc774\uc5b4\uc9c0\ub294 \uc0ac\uc5c5, \uc5f0\uac04 \uc608\uc0b0 \ud3b8\uc131\uc774 \uc788\ub294 \uacbd\uc6b0, \uad6c\uccb4\uc801 \uc218\uce58 \ubaa9\ud45c \uc5c6\uc774\ub3c4 \uc2e4\uc9c8\uc801 \ud655\ub300\uac00 \uc774\ub8e8\uc5b4\uc9c4 \uacbd\uc6b0 \ub4f1\uc785\ub2c8\ub2e4."
  },
  "4": {
    "headline": "\u0034\uc810 \u2014 \uc608\uc0b0\u00b7\uc77c\uc815 \ud655\uc815, \uc9c4\ud589 \uc911",
    "body": "\uc608\uc0b0\uc774 \uba85\ud655\ud788 \ud655\ubcf4\ub418\uace0 \uc138\ubd80 \uc77c\uc815\uae4c\uc9c0 \uc815\ud574\uc838 \ud604\uc7ac \uc9c4\ud589 \uc911\uc778 \uc0ac\uc5c5, \uc2dc\ubc94 \uc6b4\uc601, \uad6d\uac00 \uc815\ucc45 \ub4f1\uc744 \ud1b5\ud574 \uacf5\uc57d\uc774 \uc774\ud589\ub418\ub294 \uacbd\uc6b0 \ub4f1\uc785\ub2c8\ub2e4. (\uc644\ub8cc \ud655\uc815 \ub2e8\uacc4\ub294 \uc544\ub2d8 \uc218 \uc788\uc2b5\ub2c8\ub2e4.)"
  },
  "3.5": {
    "headline": "\u0033\u002e\u0035\uc810 \u2014 \ucd95\uc18c\u00b7\ubcc0\uacbd \ud6c4 \uc644\ub8cc \ub610\ub294 \ubd80\ubd84 \uc644\ub8cc",
    "body": "\uacc4\ud68d\uc774 \ucd95\uc18c\ub418\uac70\ub098 \ubcc0\uacbd\ub41c \ud615\ud0dc\ub85c \uc644\ub8cc\ub418\uc5c8\uac70\ub098, \uc77c\ubd80\ub9cc \uc644\ub8cc\ub41c \uacbd\uc6b0\uc785\ub2c8\ub2e4."
  },
  "3": {
    "headline": "\u0033\uc810 \u2014 \uc608\uc0b0\uc740 \uc788\uc73c\ub098 \uacc4\ud68d \uc870\uc815\u00b7\ucd95\uc18c \ud6c4 \uc9c4\ud589, \ub610\ub294 \uc785\ubc95 \uc9c4\uc804",
    "body": "\uc608\uc0b0\uc774 \ud3b8\uc131\ub418\uc5b4 \uc9c4\ud589 \uc911\uc774\ub098 \uacc4\ud68d\uc774 \ucd95\uc18c\u00b7\ubcc0\uacbd\ub41c \uacbd\uc6b0, \ub610\ub294 \uad00\ub828 \ubc95\uc548\u00b7\uacb0\uc758\uc548\uc774 \ud1b5\uacfc\ub41c \uacbd\uc6b0 \ub4f1\uc785\ub2c8\ub2e4. \uc785\ubc95 \uacf5\uc57d\uc740 \ubc95\uc548 \ud1b5\uacfc \uc2dc \ubcc4\ub3c4\ub85c \ub354 \ub192\uc740 \uc810\uc218\ub97c \uc904 \uc218 \uc788\ub294 \ub4f1 \uacf5\uc2dd \uae30\uc900\ud45c\uc758 \uc608\uc678 \uaddc\uc815\uc774 \uc788\uc744 \uc218 \uc788\uc2b5\ub2c8\ub2e4."
  },
  "2.5": {
    "headline": "\u0032\u002e\u0035\uc810 \u2014 \uc608\ube44\u00b7\ud0c0\ub2f9\uc131\ub9cc, \ucc29\uc218 \uc77c\uc815 \uc5c6\uc74c",
    "body": "\uc608\ube44 \ud0c0\ub2f9\uc131 \uc870\uc0ac \ub4f1\uc740 \uc788\uc73c\ub098 \uad6c\uccb4\uc801\uc778 \ucc29\uc218 \uc77c\uc815\uc774 \uc5c6\ub294 \ub2e8\uacc4\uc785\ub2c8\ub2e4."
  },
  "2": {
    "headline": "\u0032\uc810 \u2014 \ub17c\uc758 \uc704\uc8fc \ub610\ub294 \ubc95\uc548 \ubc1c\uc758 \ub2e8\uacc4",
    "body": "\ub17c\uc758\u00b7\ud611\uc758\ub9cc \uc774\ub8e8\uc5b4\uc9c0\uace0 \uad6c\uccb4\uc801 \uc77c\uc815\uc774 \uc815\ud574\uc9c0\uc9c0 \uc54a\uc740 \uacbd\uc6b0, \ub610\ub294 \uad00\ub828 \ubc95\uc548\uc774 \ubc1c\uc758\ub41c \uc218\uc900\uc785\ub2c8\ub2e4."
  },
  "1.5": {
    "headline": "\u0031\u002e\u0035\uc810 \u2014 \uacc4\ud68d\ub9cc \uc874\uc7ac",
    "body": "\uacc4\ud68d\uc740 \uc788\uc73c\ub098 \uc2e4\uc81c \ucd94\uc9c4\uc774 \ud655\uc778\ub418\uc9c0 \uc54a\ub294 \ub2e8\uacc4\uc785\ub2c8\ub2e4."
  },
  "1": {
    "headline": "\u0031\uc810 \u2014 \ud0c0 \uc8fc\uccb4 \ucd94\uc9c4\u00b7\uac08\ub4f1\u00b7\ud615\uc2dd\uc801 \ud65c\ub3d9",
    "body": "\ub2e4\ub978 \uc8fc\uccb4\uac00 \ucd94\uc9c4\ud55c \uacbd\uc6b0, \uc2ec\uac01\ud55c \uc774\uacac\uc774 \uc788\ub294 \uacbd\uc6b0, \ub2e8\uc21c \ud589\uc0ac \ucc38\uc11d \uc218\uc900 \ub4f1\uc785\ub2c8\ub2e4."
  },
  "0": {
    "headline": "\u0030\uc810 \u2014 \ubbf8\ucc29\uc218\u00b7\ubb34\uc0b0\u00b7\ud3c9\uac00 \ubd88\uac00",
    "body": "\uc0ac\uc5c5\uc774 \uc804\ud600 \ucc29\uc218\ub418\uc9c0 \uc54a\uc558\uac70\ub098 \uc815\uce58\u00b7\uacbd\uc81c\uc801 \uc774\uc720\ub85c \ubb34\uc0b0\ub41c \uacbd\uc6b0, \ub610\ub294 \uacf5\uc57d \uc790\uccb4\uac00 \ubaa8\ud638\ud574 \ud3c9\uac00\uac00 \uc5b4\ub824\uc6b4 \uacbd\uc6b0 \ub4f1\uc785\ub2c8\ub2e4."
  },
  "0.5": {
    "headline": "\u0030\u002e\u0035\uc810 \u2014 \ucd5c\ucd08\uae30 \uc911\uac04",
    "body": "\uc644\uc804 \ubbf8\ucc29\uc218\ub294 \uc544\ub2c8\ub098 \uc2e4\uc9c8\uc801 \ucd94\uc9c4\uc774 \uac70\uc758 \uc5c6\ub294 \uc0c1\ud0dc\ub85c, \uacf5\uc2dd \uae30\uc900\ud45c\uc0c1 0\uc810\uacfc 1\uc810 \uc0ac\uc774\ub97c \ub2e4\ub8ec \ub2e8\uacc4\ub85c \ubd84\ub958\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4."
  },
  "sourceNote": "\uc704 \uc124\uba85\uc740 \uad6d\ud68c \uacf5\uc57d\uc774\ud589\ub960 \ud3c9\uac00 \uccb4\uacc4\ub97c \ubc14\ud0d5\uc73c\ub85c \ud55c \uc694\uc57d\uc785\ub2c8\ub2e4. \uc138\ubd80 \ubb38\uad6c\u00b7\uc608\uc678 \uaddc\uc815\uc740 \uacf5\uc2dd \ub9e4\ub2c8\ud398\uc2a4\ud1a0\u00b7\uc790\ub8cc\ub97c \ud655\uc778\ud574 \uc8fc\uc138\uc694. \uc11c\ube44\uc2a4\ubcc4 \ud310\ub2e8 \uadfc\uac70\u00b7\ub9c1\ud06c\ub294 \uc21c\ucc28 \ubcf4\uac15 \uc608\uc815\uc785\ub2c8\ub2e4."
}
