{
  "name": "woogook_fe_test",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "node scripts/lint-tracked-files.mjs",
    "test": "npm run test:vitest && npm run test:node",
    "test:vitest": "vitest run",
    "test:node": "tsx --test tests/*.test.ts",
    "e2e": "playwright test",
    "e2e:smoke": "node scripts/e2e/local-council-smoke.mjs",
    "e2e:smoke:spec": "playwright test e2e/local-council/local-sample.spec.ts",
    "e2e:integration": "node scripts/e2e/local-council-integration.mjs",
    "e2e:integration:headed": "node scripts/e2e/local-council-integration.mjs --headed",
    "e2e:integration:debug": "node scripts/e2e/local-council-integration.mjs --debug",
    "e2e:integration:spec": "playwright test e2e/local-council/integration.spec.ts",
    "e2e:install": "playwright install chromium",
    "observability:stack:sync-env": "node scripts/observability/sync-stack-env.mjs",
    "observability:stack:config": "npm run observability:stack:sync-env && docker compose -f ops/observability/docker-compose.yml --env-file ops/observability/.env config",
    "observability:stack:up": "npm run observability:stack:sync-env && docker compose -f ops/observability/docker-compose.yml --env-file ops/observability/.env up -d",
    "observability:stack:down": "npm run observability:stack:sync-env && docker compose -f ops/observability/docker-compose.yml --env-file ops/observability/.env down -v",
    "observability:health-check": "node scripts/observability/health-check.mjs",
    "observability:emit-browser-error": "node scripts/observability/emit-browser-error.mjs",
    "observability:emit-api-5xx": "node scripts/observability/emit-api-5xx.mjs",
    "agents:sync:issue": "python3 scripts/agents_sync.py issue",
    "agents:sync:pull-request": "python3 scripts/agents_sync.py pull-request",
    "agents:sync:post-merge-report": "python3 scripts/agents_sync.py post-merge-report",
    "agents:test": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "agents:validate": "python3 scripts/validate_agents_harness.py",
    "test:local-council-samples": "sh -c 'trap \"rm -rf tmp/local-council-validation\" EXIT; rm -rf tmp/local-council-validation && tsc scripts/validate-local-council-samples.ts --module NodeNext --moduleResolution NodeNext --target ES2022 --esModuleInterop --resolveJsonModule --outDir tmp/local-council-validation --rootDir . --skipLibCheck && node tmp/local-council-validation/scripts/validate-local-council-samples.js'"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.90.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.3",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
