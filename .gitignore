# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
__pycache__/
*.py[cod]

# next.js
/.next/
/out/
/.logs/

# production
/build

# misc
.DS_Store
*.pem
/.worktrees/

# local agent runtime artifacts
/tmp/turn-flow-observability/*
# !/tmp/turn-flow-observability/turns/
# !/tmp/turn-flow-observability/turns/**
# /tmp/turn-flow-observability/active-sessions/
# /tmp/turn-flow-observability/hook-state/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!ops/observability/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# observability local stack runtime
ops/observability/.env

# data
2026_data/
