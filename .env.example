# root `/.env` 빠른 시작 예시다.
# local observability 검증을 바로 시작할 수 있게 active 값은 local 기준으로 채워 둔다.
# production 배포용 env는 이 파일을 그대로 쓰지 말고 필요한 값만 별도로 등록한다.

# ==============================
# 공통 또는 backend proxy 확인값
# ==============================

# backend proxy가 필요한 route를 확인할 때 채운다.
# origin만 넣고 path는 넣지 않는다. trailing slash는 자동 제거되지만 없는 값을 권장한다.
# local은 `127.0.0.1` 기준 예시를 유지한다.
WOOGOOK_BACKEND_BASE_URL=http://127.0.0.1:8000

# ============================
# 아래부터 local observability 전용
# production에서 observability가 필요 없으면
# 이 섹션 전체를 넣지 않아도 된다.
# ============================

# observability env 유효값은 `local`, `preview`, `production`이다.
# `production`, `preview`가 아니면 모두 `local`로 해석된다.
# 따라서 `prod`처럼 줄여 쓰면 `production`이 아니라 `local`로 동작한다.
# local stack + analyzer + Discord 검증 기본값
WOOGOOK_OBSERVABILITY_ENV=local

# boolean true 판정값은 `1`, `true`, `yes`, `on`뿐이다.
# local에서도 Loki/Grafana로 같은 이벤트를 보내려면 true가 필요하다.
WOOGOOK_OBSERVABILITY_LOCAL_MIRROR_TO_CLOUD=true

# Loki push endpoint다.
# URL이 `/loki/api/v1/push`로 끝나면 query URL을 자동 유도한다.
# 다른 형태의 ingest URL이면 아래 query URL도 직접 채운다.
WOOGOOK_OBSERVABILITY_LOKI_PUSH_URL=http://localhost:3100/loki/api/v1/push

# query URL은 비우면 push URL에서 자동 유도한다.
# WOOGOOK_OBSERVABILITY_LOKI_QUERY_URL=http://localhost:3100/loki/api/v1/query_range

# local stack 기본값은 인증이 없어 보통 필요 없다.
# WOOGOOK_OBSERVABILITY_LOKI_USERNAME=
# WOOGOOK_OBSERVABILITY_LOKI_PASSWORD=

# 비우면 analyzer는 실행되지만 Discord 발송은 건너뛴다.
WOOGOOK_OBSERVABILITY_DISCORD_WEBHOOK_URL=

# `direct` 모드에서만 사용한다.
# 비우면 LLM 보강 없이 rule-based baseline summary만 보낸다.
WOOGOOK_OBSERVABILITY_LLM_API_KEY=

# 유효값은 `direct`, `relay`다.
# `relay`가 아니면 모두 `direct`로 해석된다.
# 현재 기본 경로는 frontend 안에서 provider를 직접 호출하는 `direct` 모드다.
WOOGOOK_OBSERVABILITY_LLM_MODE=direct

# 현재 `direct` 모드에서 실제 provider 호출은 `upstage`만 지원한다.
# 다른 값을 넣으면 LLM 보강 없이 baseline summary만 사용한다.
WOOGOOK_OBSERVABILITY_LLM_PROVIDER=upstage

# `direct + upstage` 기준 OpenAI-compatible chat completions endpoint다.
WOOGOOK_OBSERVABILITY_LLM_API_URL=https://api.upstage.ai/v1/chat/completions

# provider별 실제 model id를 넣는다.
# 현재 예시는 Upstage `solar-pro3` 기준이다.
WOOGOOK_OBSERVABILITY_LLM_MODEL=solar-pro3

# `relay` 모드에서만 사용한다.
# 비우면 `relay` 모드에서도 LLM 보강 없이 baseline summary만 사용한다.
# WOOGOOK_OBSERVABILITY_LLM_WEBHOOK_URL=

# local Grafana stack 기본 연결값
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# raw Grafana `Firing`/`Resolved` 메시지를 Discord로 같이 받을 때만 채운다.
GRAFANA_ALERTS_DISCORD_WEBHOOK_URL=

# local Grafana analyzer contact point가 호출할 frontend webhook이다.
# 보통 frontend dev server 기준 `/api/observability/analyzer`를 가리킨다.
GRAFANA_ALERTS_ANALYZER_WEBHOOK_URL=http://host.docker.internal:3000/api/observability/analyzer

# Prometheus scrape target이다.
# `host:port`만 넣고 scheme이나 path는 넣지 않는다.
FRONTEND_METRICS_TARGET=host.docker.internal:3000

# 아래 값들은 기본값으로 충분해 보통 수정하지 않아도 된다.
# 비우면 local은 `local-dev`, Vercel은 commit SHA fallback을 사용한다.
# WOOGOOK_OBSERVABILITY_RELEASE=local-dev

# 비우면 `<repo>/.logs/frontend`를 사용한다.
# WOOGOOK_OBSERVABILITY_LOCAL_ROOT_DIR=.logs/frontend

# 값이 없으면 `local`에서만 true, `preview`/`production`에서는 false다.
# true 판정값은 `1`, `true`, `yes`, `on`뿐이다.
# WOOGOOK_OBSERVABILITY_WRITE_LOCAL_FILES=true

# 양의 정수만 유효하다. 잘못된 값은 기본값으로 되돌아간다.
# WOOGOOK_OBSERVABILITY_ROTATE_BYTES=52428800
# WOOGOOK_OBSERVABILITY_RETENTION_DAYS=14

# 양의 정수 초 단위다. 같은 incident key 중복 분석을 줄인다.
# WOOGOOK_OBSERVABILITY_LLM_COOLDOWN_SECONDS=900

# 양의 정수 밀리초 단위다. backend proxy, Loki, Discord, LLM 호출 timeout에 공통 사용한다.
# WOOGOOK_OBSERVABILITY_OUTBOUND_TIMEOUT_MS=5000

# 양의 정수 분 단위다. analyzer가 recent event를 조회할 lookback window다.
# WOOGOOK_OBSERVABILITY_ANALYZER_LOOKBACK_MINUTES=10
